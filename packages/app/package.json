{
  "name": "@blockpy/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@blockpy/api": "workspace:*",
    "@blockpy/blocks": "workspace:*",
    "@blockpy/editor": "workspace:*",
    "@blockpy/engine": "workspace:*",
    "@blockpy/lti-embed": "workspace:*",
    "@blockpy/navigation": "workspace:*",
    "@blockpy/quizzer": "workspace:*",
    "@blockpy/reader": "workspace:*",
    "@blockpy/textbook": "workspace:*",
    "@blockpy/vfs": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5"
  }
}
