          "content": {
            "size": 44329,
            "mimeType": "text/html; charset=utf-8",
            "compression": 0,
            "text": "\n<!DOCTYPE html>\n<html lang='en'>\n<head>\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n    <meta name=\"description\" content=\"BlockPy\">\n    <!-- The above 3 meta tags *must* come first in the head; any other head content must come *after* these tags -->\n    <title>\n    BlockPy Editor\n</title>\n    <meta property=\"og:title\" content=\"BlockPy\"/>\n    <meta property=\"og:site_name\" content=\"BlockPy Server\"/>\n    <meta property=\"og:url\" content=\"localhost\"/>\n    <meta property=\"og:description\"\n          content=\"BlockPy is a web-based Python environment that lets you work with blocks, text, or both. Designed for Data Science and equipped with powerful tools like the State Explorer and Guided Feedback, the goal of BlockPy is to let you solve authentic, real-world problems.\"/>\n\n    <link rel=\"shortcut icon\" href=\"/static/images/favicon.ico\">\n\n    <script type=text/javascript>\n        // Use $SCRIPT_ROOT to access all URLS on the server\n        window.$URL_ROOT = \"https://localhost:5000/\";\n        <!-- TODO: This needs to be able to handle missing access_token -->\n        window.accessToken = \"\"\n        \n        window.URLS_UPDATE_SUBMISSION = \"/blockpy/update_submission\";\n    </script>\n\n    \n        <script type=\"text/javascript\" src=\"/static/gen/libs.js?a28e403d\"></script>\n    \n    \n        <script type=\"text/javascript\" src=\"/static/gen/skulpt.js?951af785\"></script>\n    \n    \n        <link rel=\"stylesheet\" href=\"/static/gen/libs.css?31ac4b29\"/>\n    \n\n    <script type=\"text/javascript\" src=\"/static/libs/blockpy_server/frontend.js\"></script>\n    <link rel=\"stylesheet\" href=\"/static/libs/blockpy_server/frontend.css\">\n\n    <script>\n    class LocalTime extends HTMLElement {\n      connectedCallback() {\n        // const d = new Date(this.getAttribute(\"utc\"));\n        //this.textContent = d.toLocaleString();\n        const utc = this.getAttribute(\"utc\");\n        if (!utc || utc === \"Z\") {\n          this.textContent = \"\";\n          return;\n        }\n        try {\n            const d = frontend.prettyPrintDateTime(utc);\n            this.textContent = d;\n        } catch (e) {\n            this.textContent = utc;\n        }\n      }\n    }\n\n    customElements.define(\"local-time\", LocalTime);\n    </script>\n\n    <style>\n        \n        \n    </style>\n\n    \n\n    \n\n    <link rel=\"stylesheet\" href=\"/static/gen/blockpy.css?3ae3c223\"/>\n\n\n\n    <script type=\"text/javascript\" src=\"/static/gen/blockly.js?1b1b0023\"></script>\n\n\n\n    <script type=\"text/javascript\" src=\"/static/gen/pedal.js?05b44a86\"></script>\n\n\n\n    <script type=\"text/javascript\" src=\"/static/gen/designer.js?23d0b724\"></script>\n\n\n\n    <script type=\"text/javascript\" src=\"/static/gen/drafter.js?e4e93a0c\"></script>\n\n\n\n    <script type=\"text/javascript\" src=\"/static/gen/blockpy.js?83015a36\"></script>\n\n\n<style>\n    .embedded-data {\n        display: none;\n    }\n\n    .correct-submission {\n        background-color: #ded;\n    }\n\n    .incorrect-submission {\n        background-color: #edd;\n    }\n\n    .secret-submission {\n        background-color: #dde;\n    }\n\n    reader h4 {\n        padding-top: 10px;\n        padding-bottom: 10px;\n    }\n\n    reader blockquote {\n        padding-right: 20px;\n        font-style: italic;\n    }\n\n    reader img {\n        display: block;\n        margin-left: auto;\n        margin-right: auto;\n        max-height: 256px;\n    }\n\n    reader .reader-launch-blockpy button {\n        float: right;\n    }\n\n</style>\n\n\n\n\n    <script type=\"text/javascript\">\n        \n        \n\n        \n            $(document).ready(function () {\n                $(\"#assignments\\\\.load\").parent().addClass(\"active\");\n            });\n\n            $(function () {\n                $('[data-toggle=\"popover\"]').popover();\n            });\n        \n    </script>\n\n    <script>\n        // TODO: Extract this logic into the frontend.js (site/core.js)\n\n        function switchVisible(submissionId, showHide) {\n            $(`#h-${submissionId}-start`).toggle(!showHide);\n            $(`#h-${submissionId}-end`).toggle(showHide);\n        }\n        function logAndAlert(error, args, context) {\n            message = \"There was an error while transmitting a submission:\\n\" +\n                 context.join(\", \") + \"\\n\" +\n                (error instanceof String ? error : \n                    (('message' in error ? error.message +\"\\n\" : \"\") \n                    + \"\\nFull response:\\n\" + JSON.stringify(error)));\n            console.error(error, args);\n            alert(message);\n        }\n        function regrade(element, submission_id, hard) {\n            const assignmentName = element.getAttribute('data-assignment-name');\n            const userName = element.getAttribute('data-user-name');\n            console.log(assignmentName, userName);\n            const firstChild = element.firstElementChild;\n            let url = \"/grading/update_grading_status?submission_id=\"+submission_id;\n            if (hard) {\n                url = \"/blockpy/update_submission?submission_id=\"+submission_id;\n            }\n            \n            //console.log(this, element, submission_id);\n            firstChild.style.backgroundColor = 'white';\n            firstChild.style.color = null;\n            fetch(url, {method: 'POST'}).then((response) => {\n                return response.json()\n            }).then(response => {\n                if (response.success) {\n                    firstChild.className = \"green-check-mark\";\n                    firstChild.innerHTML = \"&#10004;\";\n                } else {\n                    firstChild.className = \"red-x\";\n                    firstChild.innerHTML = \"&#10060;\"\n                    logAndAlert(response.message, arguments, [userName, assignmentName]);\n                }\n                firstChild.style.backgroundColor = 'transparent';\n            }).catch((error) => {\n                firstChild.style.backgroundColor = 'red';\n                logAndAlert(error, arguments, [userName, assignmentName]);\n            });\n        }\n\n        function estimateDuration(element, submission_id) {\n            let url = \"/blockpy/estimate_duration?submission_id=\"+submission_id;\n            element.style.backgroundColor = 'white';\n            fetch(url, {method: 'GET'}).then((response) => {\n                return response.json()\n            }).then(response => {\n                if (response.success) {\n                    element.className = \"green-check-mark\";\n                    element.innerHTML = forHumans(response.duration);\n                } else {\n                    element.className = \"red-x\";\n                    element.innerHTML = \"&#10060;\"\n                }\n                element.style.backgroundColor = 'transparent';\n            }).catch(() => {\n                element.style.backgroundColor = 'red';\n                console.error(arguments);\n            }).finally(() => {\n            });\n        }\n\n        /**\n         * Translates seconds into human readable format of seconds, minutes, hours, days, and years\n         *\n         * @param  {number} seconds The number of seconds to be processed\n         * @return {string}         The phrase describing the amount of time\n         */\n        function forHumans ( seconds ) {\n            if (!seconds) {\n                return '0 seconds';\n            }\n            var levels = [\n                [Math.floor(seconds / 31536000), 'years'],\n                [Math.floor((seconds % 31536000) / 86400), 'days'],\n                [Math.floor(((seconds % 31536000) % 86400) / 3600), 'hours'],\n                [Math.floor((((seconds % 31536000) % 86400) % 3600) / 60), 'minutes'],\n                [Math.floor((((seconds % 31536000) % 86400) % 3600) % 60), 'seconds'],\n            ];\n            var returntext = '';\n\n            for (var i = 0, max = levels.length; i < max; i++) {\n                if ( levels[i][0] === 0 ) continue;\n                returntext += ' ' + levels[i][0] + ' ' + (levels[i][0] === 1 ? levels[i][1].substr(0, levels[i][1].length-1): levels[i][1]);\n            };\n            return returntext.trim();\n        }\n        </script>\n\n\n        <script>\n\n        function inIframe () {\n            try {\n                return window.self !== window.top;\n            } catch (e) {\n                return true;\n            }\n        }\n        function relaunchInWindow(targetUrl) {\n            if (!targetUrl) {\n                targetUrl = \"https://localhost:5000/assignments/load?grade_mode=dashboard\";\n            }\n            window.parent.postMessage(\n              {\n                subject: 'requestFullWindowLaunch',\n                data: {\n                  url: targetUrl,\n                  placement: 'course_navigation',\n                  launchType: 'new_window',\n\n                  launchOptions: {\n                    width: 1000,\n                    height: 800,\n                  },\n                },\n              },\n              '*'\n            )\n        }\n        </script>\n\n\n</head>\n<body>\n\n\n    <nav class=\"navbar navbar-expand-md navbar-dark bg-dark\">\n        <div class=\"container-fluid\">\n            <a class=\"navbar-brand\" href=\"/\">\n                <img alt=\"BlockPy Brand\"\n                     role='presentation'\n                     src=\"/static/images/blockpy-puzzle-logo.png\">\n            </a>\n            <a class=\"navbar-brand\" href=\"/\">BlockPy</a>\n            <button type=\"button\" class=\"navbar-toggler collapsed\"\n                    data-toggle=\"collapse\" data-target=\"#navbar\" aria-expanded=\"false\" aria-controls=\"navbar\"\n                    aria-label=\"Toggle navigation\">\n                <span class=\"navbar-toggler-icon\" role=\"presentation\"></span>\n            </button>\n\n            <div id=\"navbar\" class=\"collapse navbar-collapse\">\n                <ul class=\"navbar-nav mr-auto\">\n                    <li class=\"nav-item\">\n                        <a class=\"nav-link\" id='index' href=\"/\">Home</a>\n                    </li>\n                    \n                        <li class=\"nav-item\">\n                            <a class=\"nav-link\" id='courses.index' href=\"/courses/\">Courses</a>\n                        </li>\n                    \n                    <li class=\"nav-item\">\n                        <a class=\"nav-link\" id='blockpy.index' href=\"/blockpy/load\">Try Editor</a>\n                    </li>\n                    \n                </ul>\n                \n                    <a tabindex=\"0\" role=\"button\" type=\"button\" class=\"navbar-text btn btn-danger mr-4 text-white\"\n                            data-trigger=\"focus\"\n                        data-toggle=\"popover\" title=\"Guest Account\" data-content=\"You are NOT logged in as a regular user. Your work will not be saved and graded. Please use the buttons to the right to login properly!\">\n                        <span class=\"fas fa-exclamation-circle\"></span>\n                        Guest Account\n                    </a>\n                \n                <form class=\"form-inline\">\n                    \n                        <a class=\"btn mr-2 btn-light btn-sm\"\n                           href=\"/users/login\">Log in</a>\n                        <a class=\"btn btn-light btn-sm\"\n                           href=\"/users/register\">Register</a>\n                    \n                </form>\n            </div><!--/.nav-collapse -->\n        </div>\n    </nav>\n\n\n\n    <script>\n        \n    </script>\n\n\n\n<div class=\"overlay\" style=\"display:none\"></div>\n\n<div class=\"container-fluid\" role='main'>\n    \n\n    <span class='delete-on-load'>\n        Loading! Please wait. If this doesn't load, and you are using Safari, then please stop using Safari!\n        <a target=\"_blank\" href=\"/blockpy/load_assignment?assignment_id=1021&amp;course_id=3&amp;assignment_group_id=189&amp;embed=False&amp;read_only=\">Click here to try again</a>.\n    </span>\n\n    <script>\n\n    window.ltiLoadedCorrectly = frontend.checkCookies();\n    if (!frontend.checkCookies()) {\n        // alert\n        console.error(\"Cookies appear to be disabled. We will attempt to load without cookies. \" +\n            \"You might need to disable an ad-blocker, adjust your security settings, or use a different browser (we recommend Chrome).\");\n\n        // These variables will be used eventually, but right now (Jan 4, 2024), it's still expecting '*' to be the origin\n        /*let platformOIDCLoginURL = \"sso.canvaslms.com\";\n        let platformOrigin = new URL(platformOIDCLoginURL).origin;\n        let frameName = frontend.getParameterByName(\"lti_storage_target\");\n        console.log(\"++++\", frameName);\n        let parent = window.parent || window.opener;\n        let targetFrame = frameName === \"_parent\" ? parent : parent.frames[frameName];*/\n        let targetFrame = window.parent;\n        let platformOrigin = '*';\n        let messageId = frontend.generateUUID();\n        let stateId = frontend.generateUUID();\n\n        // First try to see if we can get the state and nonce values from the platform\n        // If we can't, then we'll need to generate new ones and store them.\n\n        window.addEventListener('message', function (event) {\n            // This isn't a message we're expecting\n            if (typeof event.data !== \"object\"){\n                return;\n            }\n\n            // Validate it's the response type you expect\n            if (event.data.subject !== \"lti.put_data.response\") {\n                return;\n            }\n\n            // Validate the message id matches the id you sent\n            if (event.data.message_id !== messageId) {\n                // this is not the response you're looking for\n                return;\n            }\n\n            // Validate that the event's origin is the same as the derived platform origin\n            if (event.origin !== platformOrigin) {\n                return;\n            }\n\n            // handle errors\n            if (event.data.error){\n                // handle errors\n                console.log(event.data.error.code)\n                console.log(event.data.error.message)\n                return;\n            }\n\n            // It's the response we expected\n            // The state and nonce values were successfully stored, redirect to Platform\n            console.log(\"Success! State and nonce values were stored.\");\n        });\n\n\n\n        targetFrame.postMessage({\n                \"subject\": \"lti.put_data\",\n                \"message_id\": messageId,\n                \"key\": \"blockpy_<state_id>\",\n                \"value\": \"<state_id>\"\n              } , platformOrigin )\n\n\n        targetFrame.postMessage({\n                \"subject\": \"lti.put_data\",\n                \"message_id\": messageId,\n                \"key\": \"nonce_<nonce_value>\",\n                \"value\": \"<nonce_value>\"\n              } , platformOrigin )\n    }\n    </script>\n\n    \n        \n    \n\n    \n    \n    \n        \n    \n        \n    \n        \n    \n        \n    \n        \n    \n\n    <style>\n\n        .assignment-selector-div .row {\n            border: 1px solid #faebcc;\n            border-bottom: 0;\n            background-color: #fcf8e3;\n            margin-right: 0px\n        }\n\n        .assignment-selector {\n            overflow-y: auto;\n        }\n\n    </style>\n\n    <script>\n\n        var URL_MAP = {\n            1021: \"/blockpy/load?assignment_group_id=189&assignment_id=1021&embed=False\",\n            1022: \"/blockpy/load?assignment_group_id=189&assignment_id=1022&embed=False\",\n            1023: \"/blockpy/load?assignment_group_id=189&assignment_id=1023&embed=False\",\n            1024: \"/blockpy/load?assignment_group_id=189&assignment_id=1024&embed=False\",\n            1025: \"/blockpy/load?assignment_group_id=189&assignment_id=1025&embed=False\",\n        };\n        var INDICES = [1021,1022,1023,1024,1025,];\n        var FIRST_ID = 1021;\n        var LAST_ID = 1025;\n\n        function loadNavigation() {\n            var completed = {\n                    1021:\"secret-submission\",\n                    1022:\"secret-submission\",\n                    1023:\"secret-submission\",\n                    1024:\"secret-submission\",\n                    1025:\"secret-submission\",\n            };\n            var currentId = 1021;\n\n            function updateUI(id) {\n                $(\".assignment-selector > option[value='\"+id+\"']\").prop(\"selected\", true);\n                $(\".assignment-selector-first\").attr(\"disabled\", id === FIRST_ID);\n                $(\".assignment-selector-back\").attr(\"disabled\", id === FIRST_ID);\n                $(\".assignment-selector-next\").attr(\"disabled\", id === LAST_ID);\n                $(\".assignment-selector-last\").attr(\"disabled\", id === LAST_ID);\n            }\n            updateUI(currentId);\n            var loadNewAssignment = function (id) {\n                currentId = id;\n                updateUI(id);\n                if (typeof altAssignmentChangingFunction == \"undefined\") {\n                    document.location.href = URL_MAP[id];\n                    $(\".row\").append($(\"<span>~~~ The next problem is loading! Please wait</span>\"));\n                } else {\n                    altAssignmentChangingFunction(id);\n                }\n            }\n            $(\".assignment-selector\").off().change(function (event) {\n                var id = parseInt($(event.target).val(), 10);\n                console.log(id);\n                loadNewAssignment(id);\n            });\n            $(\".assignment-selector-first\").off().click(function (event) {\n                loadNewAssignment(FIRST_ID);\n            });\n            $(\".assignment-selector-last\").off().click(function (event) {\n                loadNewAssignment(LAST_ID);\n            });\n            $(\".assignment-selector-next\").off().click(function (event) {\n                var index = INDICES.indexOf(currentId);\n                var next = INDICES[index+1] || LAST_ID;\n                loadNewAssignment(next);\n            });\n            $(\".assignment-selector-back\").off().click(function (event) {\n                var index = INDICES.indexOf(currentId);\n                var back = INDICES[index-1] || FIRST_ID;\n                loadNewAssignment(back);\n            });\n\n            // click to expand\n            function setAssignmentSelectorExpansion(state) {\n                if (state) {\n                    var length = Math.min(5, $('.assignment-selector option').length/2);\n                    $(\".assignment-selector\").attr(\"size\", length.toString());\n                    $(\".assignment-selector\").css(\"vertical-align\", \"top\");\n                } else {\n                    $(\".assignment-selector\").attr(\"size\", \"1\");\n                    $(\".assignment-selector\").css(\"vertical-align\", \"middle\");\n                }\n            }\n\n            var hasLocalStorage;\n            try {\n                localStorage;\n                hasLocalStorage = true;\n            } catch (exception) {\n                hasLocalStorage = false;\n            }\n\n            var state = hasLocalStorage && localStorage.getItem(\"blockpy_assignmentSelectorExpanded\") === \"true\";\n            setAssignmentSelectorExpansion(state);\n            $(\".completion-box\").click(function () {\n                state = !(hasLocalStorage && localStorage.getItem(\"blockpy_assignmentSelectorExpanded\") === \"true\");\n                setAssignmentSelectorExpansion(state);\n                hasLocalStorage && localStorage.setItem(\"blockpy_assignmentSelectorExpanded\", (state).toString());\n            });\n        }\n\n\n        /*\n         * Increment completed counter by 1\n         * Disable next/first/etc. butttons when at end\n         * Display message when completed all\n         */\n        function markCorrect(assignmentId) {\n            var opt = $(\".assignment-selector option[value='\" + assignmentId + \"']\");\n            if (!opt.hasClass(\"correct-submission\")) {\n                \n                    $('.completion-rate').html(\"??\");\n                \n            }\n        }\n\n    </script>\n\n    <div class='assignment-selector-div'>\n        <div class='row'>\n            <div class='col-md-12 mt-1 mb-1 ml-2 mr-2'>\n                <div class='center-block'>\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm mr-1 assignment-selector-first'>\n                        <span class=\"fas fa-step-backward\" aria-hidden=\"true\"></span>\n                        First\n                    </button>\n\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm assignment-selector-back'>\n                        <span class=\"fas fa-chevron-left\" aria-hidden=\"true\"></span>\n                        Back\n                    </button>\n\n                    <select class='assignment-selector m-1'>\n                        \n                            <option value='1021'\n                                    selected\n                                    class='secret-submission'>\n                                 0) Intro\n                            </option>\n                        \n                            <option value='1022'\n                                    \n                                    class='secret-submission'>\n                                 1) Quiz\n                            </option>\n                        \n                            <option value='1023'\n                                    \n                                    class='secret-submission'>\n                                 2) Kettle\n                            </option>\n                        \n                            <option value='1024'\n                                    \n                                    class='secret-submission'>\n                                 3) Python\n                            </option>\n                        \n                            <option value='1025'\n                                    \n                                    class='secret-submission'>\n                                 4) Outro\n                            </option>\n                        \n                    </select>\n                    <span class='completion-box m-1'>(<span class='completion-rate'>??</span>/5 completed)\n        </span>\n\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm assignment-selector-next'>\n                        Next <span class=\"fas fa-chevron-right\" aria-hidden=\"true\"></span>\n                    </button>\n\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm assignment-selector-last'>\n                        Last <span class=\"fas fa-step-forward\" aria-hidden=\"true\"></span>\n                    </button>\n                    <span class=\"float-right text-muted assignment-selector-countdown\"\n                          title=\"Time remaining (if a time limit is set)\"></span>\n                    <span class=\"float-right text-muted assignment-selector-clock\"\n                          title=\"Estimate time spent (click to get total time spent across all sessions)\">0:00</span>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    \n    \n    \n    \n    \n    <script>\n        FULL_SELECTOR_DIV = $(\".assignment-selector-div\").html();\n    </script>\n\n\n        <script>\n            $(document).ready(function () {\n                loadNavigation();\n            });\n        </script>\n    \n\n\n    <!-- Main BlockPy canvas -->\n    <div id=\"blockpy-div\" style='height:100%'></div>\n    <div id=\"extras-div\" style=\"height: 100%\">\n        <!-- ko if: assignmentType() == 'blockpy' -->\n        <blockpy params=\"server: server,\n                        courseId: courseId,\n                        currentAssignmentId: currentBlockPyAssignmentId,\n                        assignmentGroupId: assignmentGroupId,\n                        isInstructor: isInstructor,\n                        markCorrect: markCorrect,\n                        asPreamble: false,\n                        user: user\"></blockpy>\n        <!-- /ko -->\n        <!-- ko if: assignmentType() == 'textbook' -->\n        <textbook params=\"server: server,\n                          courseId: courseId,\n                          currentAssignmentId: currentTextbookAssignmentId,\n                          assignmentGroupId: assignmentGroupId,\n                          isInstructor: isInstructor,\n                          markCorrect: markCorrect,\n                          user: user\"></textbook>\n        <!-- /ko -->\n        <!-- ko if: assignmentType() == 'quiz' -->\n        <quizzer params=\"server: server,\n                         courseId: courseId,\n                         currentAssignmentId: currentQuizAssignmentId,\n                         assignmentGroupId: assignmentGroupId,\n                         isInstructor: isInstructor,\n                         markCorrect: markCorrect,\n                         user: user\"></quizzer>\n        <!-- /ko -->\n        <!-- ko if: assignmentType() == 'reading' -->\n        <reader params=\"server: server,\n                        courseId: courseId,\n                        currentAssignmentId: currentReadingAssignmentId,\n                        assignmentGroupId: assignmentGroupId,\n                        isInstructor: isInstructor,\n                        markCorrect: markCorrect,\n                        asPreamble: false,\n                        user: user\"></reader>\n        <!-- /ko -->\n        <!-- ko if: assignmentType() == 'java' -->\n        Java assignments are no longer supported in BlockPy.\n\n\n\n\n\n\n\n        <!-- /ko -->\n        <!-- ko if: assignmentType() == 'typescript' -->\n        <kettle params=\"server: server,\n                        courseId: courseId,\n                        currentAssignmentId: currentKettleAssignmentId,\n                        assignmentGroupId: assignmentGroupId,\n                        isInstructor: isInstructor,\n                        markCorrect: markCorrect,\n                        user: user\"></kettle>\n        <!-- /ko -->\n        <!-- ko if: assignmentType() == 'explain' -->\n        <explain params=\"server: server,\n                        courseId: courseId,\n                        currentAssignmentId: currentExplainAssignmentId,\n                        assignmentGroupId: assignmentGroupId,\n                        isInstructor: isInstructor,\n                        markCorrect: markCorrect,\n                        user: user\"></explain>\n        <!-- /ko -->\n    </div>\n\n    \n        \n    \n\n    \n    \n    \n        \n    \n        \n    \n        \n    \n        \n    \n        \n    \n\n    <style>\n\n        .assignment-selector-div .row {\n            border: 1px solid #faebcc;\n            border-bottom: 0;\n            background-color: #fcf8e3;\n            margin-right: 0px\n        }\n\n        .assignment-selector {\n            overflow-y: auto;\n        }\n\n    </style>\n\n    <script>\n\n        var URL_MAP = {\n            1021: \"/blockpy/load?assignment_group_id=189&assignment_id=1021&embed=False\",\n            1022: \"/blockpy/load?assignment_group_id=189&assignment_id=1022&embed=False\",\n            1023: \"/blockpy/load?assignment_group_id=189&assignment_id=1023&embed=False\",\n            1024: \"/blockpy/load?assignment_group_id=189&assignment_id=1024&embed=False\",\n            1025: \"/blockpy/load?assignment_group_id=189&assignment_id=1025&embed=False\",\n        };\n        var INDICES = [1021,1022,1023,1024,1025,];\n        var FIRST_ID = 1021;\n        var LAST_ID = 1025;\n\n        function loadNavigation() {\n            var completed = {\n                    1021:\"secret-submission\",\n                    1022:\"secret-submission\",\n                    1023:\"secret-submission\",\n                    1024:\"secret-submission\",\n                    1025:\"secret-submission\",\n            };\n            var currentId = 1021;\n\n            function updateUI(id) {\n                $(\".assignment-selector > option[value='\"+id+\"']\").prop(\"selected\", true);\n                $(\".assignment-selector-first\").attr(\"disabled\", id === FIRST_ID);\n                $(\".assignment-selector-back\").attr(\"disabled\", id === FIRST_ID);\n                $(\".assignment-selector-next\").attr(\"disabled\", id === LAST_ID);\n                $(\".assignment-selector-last\").attr(\"disabled\", id === LAST_ID);\n            }\n            updateUI(currentId);\n            var loadNewAssignment = function (id) {\n                currentId = id;\n                updateUI(id);\n                if (typeof altAssignmentChangingFunction == \"undefined\") {\n                    document.location.href = URL_MAP[id];\n                    $(\".row\").append($(\"<span>~~~ The next problem is loading! Please wait</span>\"));\n                } else {\n                    altAssignmentChangingFunction(id);\n                }\n            }\n            $(\".assignment-selector\").off().change(function (event) {\n                var id = parseInt($(event.target).val(), 10);\n                console.log(id);\n                loadNewAssignment(id);\n            });\n            $(\".assignment-selector-first\").off().click(function (event) {\n                loadNewAssignment(FIRST_ID);\n            });\n            $(\".assignment-selector-last\").off().click(function (event) {\n                loadNewAssignment(LAST_ID);\n            });\n            $(\".assignment-selector-next\").off().click(function (event) {\n                var index = INDICES.indexOf(currentId);\n                var next = INDICES[index+1] || LAST_ID;\n                loadNewAssignment(next);\n            });\n            $(\".assignment-selector-back\").off().click(function (event) {\n                var index = INDICES.indexOf(currentId);\n                var back = INDICES[index-1] || FIRST_ID;\n                loadNewAssignment(back);\n            });\n\n            // click to expand\n            function setAssignmentSelectorExpansion(state) {\n                if (state) {\n                    var length = Math.min(5, $('.assignment-selector option').length/2);\n                    $(\".assignment-selector\").attr(\"size\", length.toString());\n                    $(\".assignment-selector\").css(\"vertical-align\", \"top\");\n                } else {\n                    $(\".assignment-selector\").attr(\"size\", \"1\");\n                    $(\".assignment-selector\").css(\"vertical-align\", \"middle\");\n                }\n            }\n\n            var hasLocalStorage;\n            try {\n                localStorage;\n                hasLocalStorage = true;\n            } catch (exception) {\n                hasLocalStorage = false;\n            }\n\n            var state = hasLocalStorage && localStorage.getItem(\"blockpy_assignmentSelectorExpanded\") === \"true\";\n            setAssignmentSelectorExpansion(state);\n            $(\".completion-box\").click(function () {\n                state = !(hasLocalStorage && localStorage.getItem(\"blockpy_assignmentSelectorExpanded\") === \"true\");\n                setAssignmentSelectorExpansion(state);\n                hasLocalStorage && localStorage.setItem(\"blockpy_assignmentSelectorExpanded\", (state).toString());\n            });\n        }\n\n\n        /*\n         * Increment completed counter by 1\n         * Disable next/first/etc. butttons when at end\n         * Display message when completed all\n         */\n        function markCorrect(assignmentId) {\n            var opt = $(\".assignment-selector option[value='\" + assignmentId + \"']\");\n            if (!opt.hasClass(\"correct-submission\")) {\n                \n                    $('.completion-rate').html(\"??\");\n                \n            }\n        }\n\n    </script>\n\n    <div class='assignment-selector-div'>\n        <div class='row'>\n            <div class='col-md-12 mt-1 mb-1 ml-2 mr-2'>\n                <div class='center-block'>\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm mr-1 assignment-selector-first'>\n                        <span class=\"fas fa-step-backward\" aria-hidden=\"true\"></span>\n                        First\n                    </button>\n\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm assignment-selector-back'>\n                        <span class=\"fas fa-chevron-left\" aria-hidden=\"true\"></span>\n                        Back\n                    </button>\n\n                    <select class='assignment-selector m-1'>\n                        \n                            <option value='1021'\n                                    selected\n                                    class='secret-submission'>\n                                 0) Intro\n                            </option>\n                        \n                            <option value='1022'\n                                    \n                                    class='secret-submission'>\n                                 1) Quiz\n                            </option>\n                        \n                            <option value='1023'\n                                    \n                                    class='secret-submission'>\n                                 2) Kettle\n                            </option>\n                        \n                            <option value='1024'\n                                    \n                                    class='secret-submission'>\n                                 3) Python\n                            </option>\n                        \n                            <option value='1025'\n                                    \n                                    class='secret-submission'>\n                                 4) Outro\n                            </option>\n                        \n                    </select>\n                    <span class='completion-box m-1'>(<span class='completion-rate'>??</span>/5 completed)\n        </span>\n\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm assignment-selector-next'>\n                        Next <span class=\"fas fa-chevron-right\" aria-hidden=\"true\"></span>\n                    </button>\n\n                    <button type=\"button\" class='btn btn-outline-secondary btn-sm assignment-selector-last'>\n                        Last <span class=\"fas fa-step-forward\" aria-hidden=\"true\"></span>\n                    </button>\n                    <span class=\"float-right text-muted assignment-selector-countdown\"\n                          title=\"Time remaining (if a time limit is set)\"></span>\n                    <span class=\"float-right text-muted assignment-selector-clock\"\n                          title=\"Estimate time spent (click to get total time spent across all sessions)\">0:00</span>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    \n    \n    \n    \n    \n    <script>\n        FULL_SELECTOR_DIV = $(\".assignment-selector-div\").html();\n    </script>\n\n\n    \n\n    <script>\n        const QUIZZES = [1022];\n        const READINGS = [1021, 1025];\n        const TEXTBOOKS = [];\n        const JAVAS = [];\n        const KETTLES = [1023];\n        const EXPLAINS = [];\n        const BLOCKPYS = [1024, 1026];\n        window.$blocklyMediaPath = \"/static/blockly/media/\";\n        window.$blockPyUrls = {\n            \"importDatasets\": \"https://corgis-edu.github.io/corgis/datasets/\",\n            'loadAssignment': \"/blockpy/load_assignment\",\n            'instructionsAssignmentSetup': \"/courses/making_problems/\",\n            'forkAssignment': \"/blockpy/fork_assignment\",\n            'downloadFile': \"/blockpy/download_file?external=True\",\n            'saveAssignment': \"/blockpy/save_assignment\",\n            'loadHistory': \"/blockpy/load_history\",\n            'logEvent': \"/blockpy/log_event\",\n            'saveFile': \"/blockpy/save_file\",\n            'saveImage': \"/blockpy/save_image\",\n            'listUploadedFiles': \"/blockpy/list_files\",\n            'uploadFile': \"/blockpy/upload_file\",\n            'renameFile': \"/blockpy/rename_file\",\n            'updateSubmission': \"/blockpy/update_submission\",\n            'updateSubmissionStatus': \"/blockpy/update_submission_status\",\n            \"openaiProxy\": \"/blockpy/openai\",\n            \"shareUrl\": \"https://localhost:5000/blockpy/share/\",\n        };\n        window.$blockPyUserData = {\n            \"user.id\": 5589,\n            \n            \"user.name\": \"e7e803e8ba0f44ad8185034fdf72f098 UNKNOWN:127.0.0.1\",\n            \n            \"user.role\": \"student\",\n            \"user.course_id\": 3,\n            \"access_token\": window.accessToken,\n        };\n\n\n\n        $(document).ready(function () {\n            // Load in Quiz interface\n            let loggedInUser = {\"email\": \"\", \"first_name\": \"e7e803e8ba0f44ad8185034fdf72f098\", \"id\": 5589, \"last_name\": \"UNKNOWN:127.0.0.1\"};\n            server = new frontend.Server(3, {\n            }, {\n                users: [loggedInUser],\n                courses: []\n            });\n            mainModel = {\n                courseId: 3,\n                server: server,\n                user: loggedInUser,\n                isInstructor: false,\n                currentQuizAssignmentId: ko.observable(null),\n                currentReadingAssignmentId: ko.observable(null),\n                currentTextbookAssignmentId: ko.observable(null),\n                currentJavaAssignmentId: ko.observable(null),\n                currentKettleAssignmentId: ko.observable(null),\n                currentExplainAssignmentId: ko.observable(null),\n                currentBlockPyAssignmentId: ko.observable(null),\n                assignmentType: ko.observable(null),\n                assignmentGroupId: 189,\n                markCorrect: markCorrect\n            }\n            ko.applyBindings(mainModel, $(\"#extras-div\")[0]);\n\n\n\n            // Load in BlockPy interface\n            editor = new blockpy.BlockPy({\n                // Configuration constants\n                'blockly.path': window.$blocklyMediaPath,\n                'attachment.point': '#blockpy-div',\n                \"urls\": window.$blockPyUrls,\n                // User information\n                ...window.$blockPyUserData,\n\n                // Group Information\n                \n                    \"user.group_id\": 189,\n                    'callback.success': markCorrect,\n                \n\n                \n\n                \n            \n                \"access_token\": window.accessToken,\n\n                \n                    \n                \n                    \n                \n            });\n\n            Sk.emojiProxy = (part) => `/static/images/emoji/${part.toLowerCase()}.svg`;\n\n            $MAIN_BLOCKPY_EDITOR = editor;\n\n            /* Passcode locking */\n            \n\n            // System for switching assignments\n            function loadAssignmentWrapper(id) {\n                const [isQuiz, isReading, isTextbook, isJava, isKettle, isExplain, isBlockPy] = [\n                    QUIZZES, READINGS, TEXTBOOKS, JAVAS, KETTLES, EXPLAINS, BLOCKPYS\n                ].map((list) => list.includes(id));\n\n                id = parseInt(id, 10);\n                if ([isQuiz, isReading, isTextbook, isJava, isKettle, isExplain].some(Boolean)) {\n                    editor.hide();\n                    mainModel.assignmentType(\n                        isQuiz ? 'quiz' :\n                            isReading ? 'reading' :\n                                isTextbook ? 'textbook' :\n                                    isJava ? 'java' :\n                                        isKettle ? 'typescript' :\n                                            isExplain ? 'explain' :\n                                                isBlockPy ? 'blockpy' :\n                                                    null);\n                } else {\n                    editor.show();\n                    const whenDone = editor.loadAssignment(id);\n                    if (whenDone) {\n                        whenDone.done(() => {\n                            console.log(editor, isBlockPy, id);\n                            mainModel.assignmentType(isBlockPy ? 'blockpy' : null);\n                            mainModel.currentBlockPyAssignmentId(isBlockPy ? id : null);\n                        })\n                    }\n                }\n                mainModel.currentQuizAssignmentId(isQuiz ? id : null);\n                mainModel.currentReadingAssignmentId(isReading ? id : null);\n                mainModel.currentTextbookAssignmentId(isTextbook ? id : null);\n                mainModel.currentJavaAssignmentId(isJava ? id : null);\n                mainModel.currentKettleAssignmentId(isKettle ? id : null);\n                mainModel.currentExplainAssignmentId(isExplain ? id : null);\n            }\n\n            // And/Or load assignment data explicitly passed in\n            \n                loadAssignmentWrapper(1021);\n                //editor.loadAssignment(1021);\n                altAssignmentChangingFunction = loadAssignmentWrapper; //editor.loadAssignment.bind(editor);\n            \n\n            // Snippet that handles intelligent resizing\n            \n\n            // Remove the loading screen\n            $('.delete-on-load').remove();\n\n            // window.parent.postMessage(JSON.stringify({subject: \"lti.fetchWindowSize\"}), \"*\")\n            // window.addEventListener('message', function(event) { console.log(JSON.parse(event.data)); })\n\n\n        });\n    </script>\n\n\n    <script>\n        //test = $(\".assignment-selector-div\").html();\n        window.ACTIVITY_GET_DURATION = () => {\n            return $.get(\"/blockpy/estimate_group_duration?assignment_group_id=189\\u0026course_id=3\").then((result) => {\n                return result.duration;\n            });\n        };\n        const pageStartTime = 0 || Date.now();\n        let activityDuration = 0;\n        let clockMode = 'session';\n        function refreshClock() {\n            if (clockMode != 'loading') {\n                const duration = Math.floor((Date.now() - pageStartTime)/1000 + activityDuration);\n                const hours = Math.floor(duration/60/60);\n                let oMinutes = Math.floor(duration/60 % 60);\n                let minutes = oMinutes < 10 ? \"0\"+oMinutes : oMinutes;\n                if (hours >= 99) {\n                    $(\".assignment-selector-clock\").html(`99+ hours spent`);\n                } else if (hours < 1) {\n                    if (oMinutes < 1) {\n                        $(\".assignment-selector-clock\").html(`(Just started)`);\n                    } else if (oMinutes === 1) {\n                        $(\".assignment-selector-clock\").html(`~${oMinutes} minute spent`);\n                    } else {\n                        $(\".assignment-selector-clock\").html(`~${oMinutes} minutes spent`);\n                    }\n                } else {\n                    $(\".assignment-selector-clock\").html(`~${hours}:${minutes} hours spent`);\n                }\n            } else {\n                $(\".assignment-selector-clock\").html(`(Getting Total)`);\n            }\n        };\n        $(function() {\n            refreshClock();\n            setInterval(refreshClock, 10000);\n            $(\".assignment-selector-clock\").click(() => {\n                if (clockMode == 'session') {\n                    if (typeof window.ACTIVITY_GET_DURATION !== 'undefined') {\n                        clockMode = 'loading';\n                        window.ACTIVITY_GET_DURATION().done((result) => {\n                            activityDuration = result;\n                            clockMode = 'activity';\n                        }).catch((err) => {\n                            console.error(err);\n                            clockMode = 'session';\n                            activityDuration = 0;\n                        }).always(() => {\n                            refreshClock();\n                        });\n                    }\n                } else {\n                    activityDuration = 0;\n                    clockMode = 'session';\n                }\n                refreshClock();\n            })\n        });\n    </script>\n    <!--<span id=\"assignment-time-remaining-clock\"></span>-->\n\n\n</div>\n\n\n<!-- begin footer -->\n<hr/>\n<footer class=\"footer\" style=\"margin-top:20px;\">\n    <div class=\"container-fluid\">\n        <p class=\"pull-right\">\n            \n                \n                    You are a guest user<span> (e7e803e8ba0f44ad8185034fdf72f098)</span>\n                \n                \n                | <a href=\"#\">Back to top</a>\n            \n        </p>\n        <p>\n        